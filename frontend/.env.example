# Vite Configuration
# When running via docker-compose, use /api so Vite's proxy forwards to the backend container
VITE_API_URL_DOCKER=/api

# API Proxy URL (for development without Docker)
VITE_API_PROXY_URL=http://localhost:3000

# Supabase (if needed directly from frontend)
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key
